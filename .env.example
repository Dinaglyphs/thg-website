# Copy this file to ".env" and fill in the values.

# A long random string used to sign tokens. Generate one with:  openssl rand -base64 32
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Local SQLite database file (zero-config for local dev).
DATABASE_URI=file:./thg.db

# In PRODUCTION (Vercel), point these at a hosted Turso (libSQL) database instead:
#   DATABASE_URI=libsql://your-db-name.turso.io
#   DATABASE_AUTH_TOKEN=your-turso-auth-token
# DATABASE_AUTH_TOKEN is ignored locally.

# The public URL of the site (used by Payload for links/CORS).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
